{
  "name": "pr-scout",
  "version": "0.2.0",
  "description": "CLI that scores good first issues in any GitHub repo using an LLM — cuts through spam and finds the real ones",
  "type": "module",
  "bin": {
    "pr-scout": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github",
    "issues",
    "good-first-issue",
    "cli",
    "open-source",
    "llm",
    "groq",
    "contributor"
  ],
  "author": "vukkt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vukkt/pr-scout.git"
  },
  "homepage": "https://github.com/vukkt/pr-scout#readme",
  "bugs": {
    "url": "https://github.com/vukkt/pr-scout/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@octokit/rest": "^21.0.0",
    "commander": "^13.0.0",
    "open": "^10.0.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
